# ── InkDown Environment Variables ────────────────────────────
#
# Copy this file to .env and fill in your values.
# The server reads these at startup via process.env.
#
# Usage:
#   cp .env.example .env
#   node server.js        (reads .env automatically if you use dotenv)
#   PORT=3000 node server.js   (or export inline)


# ── Server ────────────────────────────────────────────────────

# Port to listen on (default: 3000)
PORT=3000


# ── API Authentication ────────────────────────────────────────
#
# Comma-separated list of valid API keys.
# If not set (or empty), the /api/v1/convert endpoint is open to all callers.
# The legacy /api/convert route (used by the web UI) is always open.
#
# Clients send the key as:
#   X-API-Key: <key>
# or:
#   Authorization: Bearer <key>
#
# Example (generate with: openssl rand -hex 32):
# INKDOWN_API_KEYS=abc123secretkey,anotherkey456


# ── CORS ──────────────────────────────────────────────────────
#
# Comma-separated list of allowed origins for cross-origin requests.
# Defaults to * (allow all) if not set.
# Set this in production to restrict which domains can call your API.
#
# INKDOWN_CORS_ORIGINS=https://myapp.com,https://staging.myapp.com
