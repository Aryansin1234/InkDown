{
  "name": "inkdown",
  "version": "1.0.0",
  "description": "Turn Markdown into pixel-perfect PDF and DOCX documents — syntax highlighting, smart tables, page control, and more.",
  "main": "src/converter.js",
  "bin": {
    "md2pdf": "./src/cli.js"
  },
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "convert": "node src/cli.js",
    "test": "node src/cli.js samples/master-test.md output/test.pdf",
    "test:docx": "node src/cli.js --format docx samples/master-test.md output/test.docx"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "highlight.js": "^11.10.0",
    "katex": "^0.16.45",
    "marked": "^13.0.0",
    "marked-footnote": "^1.4.0",
    "marked-katex-extension": "^5.1.8",
    "mermaid": "^11.14.0",
    "multer": "^2.1.1",
    "puppeteer": "^24.40.0",
    "remark-gfm": "^3.0.1",
    "remark-parse": "^10.0.2",
    "remark-stringify": "^10.0.3",
    "unified": "^10.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
